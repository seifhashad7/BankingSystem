<UserControl x:Class="BankingSystem.Views.CustomerDashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:BankingSystem.Views"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <TextBlock Margin="0 10 0 10" FontSize="15" FontWeight="Bold">Customer Dashboard</TextBlock>
            <TextBlock>Please Enter Customer Id:</TextBlock>
            <TextBox Width="70" HorizontalAlignment="Left" Margin="0 10 0 10" Text="{Binding Id}"></TextBox>
        </StackPanel>
        
        <WrapPanel Grid.Row="1" Margin="-5 0 0 0">
            <WrapPanel.Resources>
                <Style TargetType="Button">
                    <Style.Setters>
                        <Setter Property="Margin" Value="5"/>
                        <Setter Property="Width" Value="auto"/>
                        <Setter Property="HorizontalAlignment" Value="Left"/>
                        <Setter Property="Padding" Value="3"/>
                    </Style.Setters>
                </Style>
            </WrapPanel.Resources>
            <Button Content="Customer Transactions" Command="{Binding LoadTransactionsCommand}"/>
            <Button Content="Customer Accounts" Command="{Binding LoadAccountsCommand}"/>
            <Button Content="Customer Total Balance" Command="{Binding LoadTotalBalanceCommand}"/>
            <Button Content="Total Transactions" Command="{Binding LoadTotalTransactionsCommand}"/>
        </WrapPanel>

        <DataGrid x:Name="MainDisplayGrid" Grid.Row="2" Margin="0,10,0,0" ItemsSource="{Binding CurrentGridData}" AutoGenerateColumns="True" IsReadOnly="True"/>
        <ContentControl Grid.Row="1" Content="{Binding CurrentView}" HorizontalAlignment="Stretch" VerticalAlignment="Stretch"></ContentControl>
        
        <Button Grid.Row="3" Width="100" Margin="0 5 0 0" Command="{Binding LoadHomeViewCommand}"> Back </Button>
    </Grid>
</UserControl>
