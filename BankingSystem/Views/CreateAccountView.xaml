<UserControl x:Class="BankingSystem.Views.CreateAccountView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:BankingSystem.Views"
             mc:Ignorable="d" 
             d:DesignHeight="500" d:DesignWidth="800">
    <Grid Background="White" Margin="0 20 0 0" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
        <Grid.Resources>
            <Style TargetType="Label">
                <Setter Property="FontSize" Value="15" />
                <Setter Property="FontFamily" Value="Calibri" />
                <Setter Property="FontWeight" Value="Bold" />
                <Setter Property="Margin" Value="5 0 0 0" />
            </Style>

            <Style TargetType="TextBox">
                <Setter Property="HorizontalAlignment" Value="Left" />
                <Setter Property="Margin" Value="10 0 0 0" />
                <Setter Property="Width" Value="200" />
                <Setter Property="Height" Value="20" />
            </Style>

            <Style TargetType="RadioButton">
                <Setter Property="Width" Value="100" />
                <Setter Property="Height" Value="15" />
                <Setter Property="Margin" Value="10 0 0 0" />
                <Setter Property="FontSize" Value="10"/>
                <Setter Property="HorizontalAlignment" Value="Left" />
            </Style>

            <Style TargetType="CheckBox">
                <Setter Property="Width" Value="auto" />
                <Setter Property="Height" Value="auto" />
                <Setter Property="Margin" Value="10 5 0 0" />
                <Setter Property="FontSize" Value="10"/>
                <Setter Property="HorizontalAlignment" Value="Left" />
            </Style>
        </Grid.Resources>

        <Grid.RowDefinitions>
            <RowDefinition Height="auto"></RowDefinition>
            <RowDefinition Height="auto"></RowDefinition>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"></ColumnDefinition>
            <ColumnDefinition Width="*"></ColumnDefinition>
        </Grid.ColumnDefinitions>

        <StackPanel Grid.Row="0" HorizontalAlignment="Center">
            <Label>Please Enter your Full Name:</Label>
            <TextBox Text="{Binding Name}"/>

            <Label>Please Enter your Age:</Label>
            <TextBox Text="{Binding Age}"/>

            <Label>Please Enter your National ID:</Label>
            <TextBox Text="{Binding NationalId}"/>

            <Label>Please Enter your Phone Number:</Label>
            <TextBox Text="{Binding PhoneNumber}"/>

            <Label>Please Enter your Address:</Label>
            <TextBox Text="{Binding Address}"/>
        </StackPanel>

        <Grid Grid.Column="1" HorizontalAlignment="Center">
            <Grid.RowDefinitions>
                <RowDefinition Height="auto"></RowDefinition>
                <RowDefinition Height="auto"></RowDefinition>
                <RowDefinition Height="auto"></RowDefinition>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Margin="0 0 0 40">
                <Label>Please choose your gender:</Label>
                <RadioButton GroupName="GenderGroup" Content="Male" IsChecked="{Binding IsMaleSelected}"/>
                <RadioButton GroupName="GenderGroup"  Content="Female" IsChecked="{Binding IsFemaleSelected}"/>
            </StackPanel>

            <StackPanel Grid.Row="1" Margin="0 0 0 40">
                <Label>Please choose account type:</Label>
                <RadioButton GroupName="AccountGroup" Content="Salary Account" IsChecked="{Binding IsSalaryAccSelected}"/>
                <RadioButton GroupName="AccountGroup" Content="Saving Account" IsChecked="{Binding IsSavingAccSelected}"/>
            </StackPanel>

            <StackPanel Grid.Row="2" Margin="0 0 0 10">
                <Label>Please Enter initial balance:</Label>
                <TextBox Text="{Binding InitialBalance}"/>
            </StackPanel>
        </Grid>
        
        <WrapPanel Grid.Row="1" Grid.ColumnSpan="2" HorizontalAlignment="Center">
            <WrapPanel.Resources>
                <Style TargetType="Button">
                    <Style.Setters>
                        <Setter Property="Width" Value="50"></Setter>
                        <Setter Property="Height" Value="20"></Setter>
                        <Setter Property="Margin" Value="10 10 0 0"></Setter>
                        <Setter Property="HorizontalAlignment" Value="Left"></Setter>
                        <Setter Property="FontSize" Value="10"></Setter>
                    </Style.Setters>
                </Style>
            </WrapPanel.Resources>
            <Button Name="SubmitButton" Command="{Binding SubmitCommand}" CommandParameter="CreateMode">Submit</Button>
            <Button Name="BackButton" Command="{Binding BackCommand}">Back</Button>
        </WrapPanel>
        <ContentControl Grid.Row="0" Grid.RowSpan="2" Panel.ZIndex="1" Content="{Binding CurrentView}"></ContentControl>
    </Grid>
</UserControl>
