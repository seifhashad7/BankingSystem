<UserControl x:Class="BankingSystem.Views.CertificateView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:BankingSystem.Views"
             mc:Ignorable="d" 
             d:DesignHeight="500" d:DesignWidth="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="auto"></RowDefinition>
            <RowDefinition Height="auto"></RowDefinition>
            <RowDefinition Height="auto"></RowDefinition>
            <RowDefinition Height="auto"></RowDefinition>
            <RowDefinition Height="auto"></RowDefinition>
            <RowDefinition Height="auto"></RowDefinition>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" FontFamily="Calibri" FontSize="15" FontWeight="Bold" Margin="10"> Certificate Operations</TextBlock>

        <StackPanel Grid.Row="1" Margin="10" HorizontalAlignment="Left">
            <TextBlock FontSize="10" Margin="0 0 0 5"> Customer Id</TextBlock>
            <TextBox Width="100" Text="{Binding CustomerId}"></TextBox>
        </StackPanel>

        <StackPanel Grid.Row="2" Margin="10" HorizontalAlignment="Left">
            <TextBlock FontSize="10" Margin="0 0 0 5"> Certificate Id </TextBlock>
            <TextBox Width="100" Text="{Binding CertificateId}"></TextBox>
        </StackPanel>

        <StackPanel Grid.Row="3" Margin="10" HorizontalAlignment="Left">
            <TextBlock FontSize="10" Margin="0 0 0 5"> Certificate Period </TextBlock>
            <TextBox Width="100" Text="{Binding Period}"></TextBox>
        </StackPanel>

        <StackPanel Grid.Row="4" Margin="10" HorizontalAlignment="Left">
            <TextBlock FontSize="10" Margin="0 0 0 5"> Certificate Price</TextBlock>
            <TextBox Width="100" Text="{Binding PrincipalAmount}"></TextBox>
        </StackPanel>

        <WrapPanel Grid.Row="5" Margin="5 10 10 10" HorizontalAlignment="Left">
            <WrapPanel.Resources>
                <Style TargetType="Button">
                    <Style.Setters>
                        <Setter Property="Width" Value="auto"></Setter>
                        <Setter Property="Height" Value="20"></Setter>
                        <Setter Property="Margin" Value="5 0 0 0"></Setter>
                        <Setter Property="FontSize" Value="10"></Setter>
                    </Style.Setters>
                </Style>
            </WrapPanel.Resources>
            <Button Command="{Binding IssueCertificateCommand}">Issue new Certificate</Button>
            <Button Command="{Binding ModifyCertificateCommand}">Update Certificate data</Button>
            <Button Command="{Binding DeleteCertificateCommand}">Delete Certificate</Button>
        </WrapPanel>
    </Grid>
</UserControl>
